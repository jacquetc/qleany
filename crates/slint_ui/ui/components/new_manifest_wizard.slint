import { CheckBox } from "std-widgets.slint";
import { StyledButton, StyledLineEdit, FormField, Paper } from "misc.slint";
import { NewManifestWizardState, CommonTools } from "../globals.slint";

component RadioOption inherits Rectangle {
    in property <string> label;
    in property <string> description;
    in property <bool> selected: false;
    callback clicked();

    height: 52px;
    background: selected ? #e7f5ff : (touch.has-hover ? #f8f9fa : transparent);
    border-width: selected ? 2px : 1px;
    border-color: selected ? #228be6 : #dee2e6;
    border-radius: 8px;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding: 12px;
        spacing: 12px;
        alignment: start;

        // Radio circle
        Rectangle {
            width: 20px;
            height: 20px;
            border-radius: 10px;
            border-width: 2px;
            border-color: selected ? #228be6 : #adb5bd;
            background: #ffffff;

            Rectangle {
                width: 10px;
                height: 10px;
                x: 3px;
                y: 3px;
                border-radius: 5px;
                background: selected ? #228be6 : transparent;
            }
        }

        VerticalLayout {
            spacing: 2px;
            alignment: center;

            Text {
                text: label;
                font-size: 14px;
                font-weight: 600;
                color: selected ? #1971c2 : #212529;
            }

            if description != "" : Text {
                text: description;
                font-size: 12px;
                color: #868e96;
            }
        }
    }
}

component StepIndicator inherits HorizontalLayout {
    in property <int> current-step: 0;
    in property <[string]> steps: ["Language", "Project", "Template", "UI Options"];

    spacing: 0px;
    alignment: center;

    for step-label[i] in steps : HorizontalLayout {
        spacing: 0px;

        Rectangle {
            width: 28px;
            height: 28px;
            border-radius: 14px;
            background: i <= current-step ? #228be6 : #dee2e6;

            Text {
                text: i + 1;
                font-size: 12px;
                font-weight: 600;
                color: i <= current-step ? #ffffff : #868e96;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        if i < steps.length - 1 : VerticalLayout {
            alignment: center;
            Rectangle {
                width: 40px;
                height: 2px;
                background: i < current-step ? #228be6 : #dee2e6;
            }
        }
    }
}

export component NewManifestWizard inherits Rectangle {
    callback cancelled();
    callback confirmed();

    // Semi-transparent background overlay
    background: #00000080;

    // Block clicks on the background
    TouchArea {
        clicked => { root.cancelled(); }
    }

    // Center the dialog
    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        z: 1;
        width: 560px;
        height: 480px;
        background: #ffffff;
        border-radius: 12px;
        drop-shadow-blur: 16px;
        drop-shadow-color: #00000040;
        drop-shadow-offset-y: 4px;

        // Block clicks from propagating through dialog
        TouchArea {}

        VerticalLayout {
            padding: 24px;
            spacing: 16px;

            // Title
            Text {
                text: "New Manifest";
                font-size: 20px;
                font-weight: 700;
                color: #212529;
                horizontal-alignment: center;
            }

            // Step indicator
            StepIndicator {
                current-step: NewManifestWizardState.step;
            }

            // Content area
            Rectangle {
                vertical-stretch: 1;

                // Step 0: Language
                if NewManifestWizardState.step == 0 : VerticalLayout {
                    spacing: 12px;
                    padding-top: 8px;

                    Text {
                        text: "Choose the target language:";
                        font-size: 14px;
                        color: #495057;
                    }

                    RadioOption {
                        label: "C++/Qt";
                        description: "C++ 20 and Qt 6";
                        selected: NewManifestWizardState.language_index == 0;
                        clicked => { NewManifestWizardState.language_index = 0; }
                    }

                    RadioOption {
                        label: "Rust";
                        description: "2024 edition";
                        selected: NewManifestWizardState.language_index == 1;
                        clicked => { NewManifestWizardState.language_index = 1; }
                    }
                }

                // Step 1: Names
                if NewManifestWizardState.step == 1 : VerticalLayout {
                    spacing: 16px;
                    padding-top: 8px;

                    FormField {
                        label: "Application Name";
                        required: true;
                        error-message: NewManifestWizardState.name_error;

                        StyledLineEdit {
                            text: NewManifestWizardState.application_name;
                            placeholder: "MyApp (PascalCase)";
                            has-error: NewManifestWizardState.name_error != "";
                            edited(val) => {
                                NewManifestWizardState.application_name = val;
                                if val == "" {
                                    NewManifestWizardState.name_error = "Required";
                                } else if !CommonTools.check_is_pascal_case(val) {
                                    NewManifestWizardState.name_error = "Must be PascalCase";
                                } else {
                                    NewManifestWizardState.name_error = "";
                                }
                            }
                        }
                    }

                    FormField {
                        label: "Organisation Name";
                        required: true;
                        error-message: NewManifestWizardState.org_error;

                        StyledLineEdit {
                            text: NewManifestWizardState.organization_name;
                            placeholder: "MyOrganization";
                            has-error: NewManifestWizardState.org_error != "";
                            edited(val) => {
                                NewManifestWizardState.organization_name = val;
                                if val == "" {
                                    NewManifestWizardState.org_error = "Required";
                                } else {
                                    NewManifestWizardState.org_error = "";
                                }
                            }
                        }
                    }

                    Rectangle {

                        width: parent.width;
                        vertical-stretch: 1;
                    }
                }

                // Step 2: Template
                if NewManifestWizardState.step == 2 : VerticalLayout {
                    spacing: 8px;
                    padding-top: 8px;

                    Text {
                        text: "Choose a starting template:";
                        font-size: 14px;
                        color: #495057;
                    }

                    RadioOption {
                        label: "Blank";
                        description: "EntityBase + empty Root. Start from scratch.";
                        selected: NewManifestWizardState.template_index == 0;
                        clicked => { NewManifestWizardState.template_index = 0; }
                    }

                    RadioOption {
                        label: "Minimal";
                        description: "Root with one entity (Item). Hello world equivalent.";
                        selected: NewManifestWizardState.template_index == 1;
                        clicked => { NewManifestWizardState.template_index = 1; }
                    }

                    RadioOption {
                        label: "Document Editor";
                        description: "Documents > Sections with load/save use cases.";
                        selected: NewManifestWizardState.template_index == 2;
                        clicked => { NewManifestWizardState.template_index = 2; }
                    }

                    RadioOption {
                        label: "Data Management";
                        description: "Items, Categories, Tags with import/export use cases.";
                        selected: NewManifestWizardState.template_index == 3;
                        clicked => { NewManifestWizardState.template_index = 3; }
                    }
                }

                // Step 3: UI Options
                if NewManifestWizardState.step == 3 : VerticalLayout {
                    spacing: 12px;
                    padding-top: 8px;

                    Text {
                        text: "Select UI frontends to enable:";
                        font-size: 14px;
                        color: #495057;
                    }

                    // Show C++/Qt options when language is C++/Qt
                    if NewManifestWizardState.language_index == 0 : VerticalLayout {
                        spacing: 8px;

                        CheckBox {
                            text: "Qt Quick (QML)";
                            checked: NewManifestWizardState.opt_cpp_qt_qtquick;
                            toggled => { NewManifestWizardState.opt_cpp_qt_qtquick = self.checked; }
                        }

                        CheckBox {
                            text: "Qt Widgets";
                            checked: NewManifestWizardState.opt_cpp_qt_qtwidgets;
                            toggled => { NewManifestWizardState.opt_cpp_qt_qtwidgets = self.checked; }
                        }

                        Text {
                            text: "Qt Quick is recommended for new projects, but you can enable both if you want.";
                            font-size: 12px;
                            color: #868e96;
                        }

                        Text {
                            text: "If not already done, create a git repository and commit the initial manifest, and tag:\n'git init && git add . && git commit -m\"initial commit\" && git tag v0.0.1'\n\nA git tag is mandatory with a C++/Qt manifest";
                            font-size: 12px;
                            color: #868e96;
                        }
                    }

                    // Show Rust options when language is Rust
                    if NewManifestWizardState.language_index == 1 : VerticalLayout {
                        spacing: 8px;

                        CheckBox {
                            text: "CLI";
                            checked: NewManifestWizardState.opt_rust_cli;
                            toggled => { NewManifestWizardState.opt_rust_cli = self.checked; }
                        }

                        CheckBox {
                            text: "Slint (Desktop GUI)";
                            checked: NewManifestWizardState.opt_rust_slint;
                            toggled => { NewManifestWizardState.opt_rust_slint = self.checked; }
                        }
                    }

                    Text {
                        text: "You can change these later in the User Interface tab.";
                        font-size: 12px;
                        color: #868e96;
                    }
                }
            }

            // Navigation buttons
            HorizontalLayout {
                spacing: 12px;
                alignment: end;

                StyledButton {
                    text: "Cancel";
                    clicked => { root.cancelled(); }
                }

                if NewManifestWizardState.step > 0 : StyledButton {
                    text: "Back";
                    clicked => {
                        NewManifestWizardState.step = NewManifestWizardState.step - 1;
                    }
                }

                if NewManifestWizardState.step < 3 : StyledButton {
                    text: "Next";
                    primary: true;
                    enabled: NewManifestWizardState.step != 1 || (NewManifestWizardState.application_name != "" && NewManifestWizardState.name_error == "" && NewManifestWizardState.organization_name != "" && NewManifestWizardState.org_error == "");
                    clicked => {
                        NewManifestWizardState.step = NewManifestWizardState.step + 1;
                    }
                }

                if NewManifestWizardState.step == 3 : StyledButton {
                    text: "Create";
                    primary: true;
                    clicked => { root.confirmed(); }
                }
            }
        }
    }
}
