import { ProgressIndicator } from "std-widgets.slint";
import { StyledButton, StyledLineEdit, FormField, Paper } from "misc.slint";
import { DemoWizardState } from "../globals.slint";

component RadioOption inherits Rectangle {
    in property <string> label;
    in property <string> description;
    in property <bool> selected: false;
    callback clicked();

    height: 52px;
    background: selected ? #e7f5ff : (touch.has-hover ? #f8f9fa : transparent);
    border-width: selected ? 2px : 1px;
    border-color: selected ? #228be6 : #dee2e6;
    border-radius: 8px;

    touch := TouchArea {
        clicked => { root.clicked(); }
    }

    HorizontalLayout {
        padding: 12px;
        spacing: 12px;
        alignment: start;

        Rectangle {
            width: 20px;
            height: 20px;
            border-radius: 10px;
            border-width: 2px;
            border-color: selected ? #228be6 : #adb5bd;
            background: #ffffff;

            Rectangle {
                width: 10px;
                height: 10px;
                x: 3px;
                y: 3px;
                border-radius: 5px;
                background: selected ? #228be6 : transparent;
            }
        }

        VerticalLayout {
            spacing: 2px;
            alignment: center;

            Text {
                text: label;
                font-size: 14px;
                font-weight: 600;
                color: selected ? #1971c2 : #212529;
            }

            if description != "" : Text {
                text: description;
                font-size: 12px;
                color: #868e96;
            }
        }
    }
}

component CopyableCommand inherits Rectangle {
    in property <string> command;
    in property <bool> copied: false;
    callback copy();

    height: 40px;
    background: #f1f3f5;
    border-radius: 6px;
    border-width: 1px;
    border-color: #dee2e6;

    HorizontalLayout {
        padding-left: 12px;
        padding-right: 4px;
        spacing: 8px;

        Text {
            text: command;
            font-size: 13px;
            font-family: "monospace";
            color: #212529;
            vertical-alignment: center;
            horizontal-stretch: 1;
            overflow: elide;
        }

        Rectangle {
            width: 32px;
            height: 32px;
            border-radius: 4px;
            background: copy-touch.pressed ? #dee2e6 : (copy-touch.has-hover ? #e9ecef : transparent);

            copy-touch := TouchArea {
                clicked => { root.copy(); }
                mouse-cursor: pointer;
            }

            Text {
                text: copied ? "\u{2713}" : "\u{2398}";
                font-size: 16px;
                color: copied ? #2b8a3e : #868e96;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
}

export component DemoWizard inherits Rectangle {
    callback cancelled();

    background: #00000080;

    TouchArea {
        clicked => {
            if (!DemoWizardState.is_running) {
                root.cancelled();
            }
        }
    }

    Rectangle {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        z: 1;
        width: 560px;
        height: DemoWizardState.completed ? 540px : 420px;
        background: #ffffff;
        border-radius: 12px;
        drop-shadow-blur: 16px;
        drop-shadow-color: #00000040;
        drop-shadow-offset-y: 4px;
        animate height { duration: 200ms; easing: ease-out; }

        TouchArea {}

        VerticalLayout {
            padding: 24px;
            spacing: 16px;

            Text {
                text: "Run Demo";
                font-size: 20px;
                font-weight: 700;
                color: #212529;
                horizontal-alignment: center;
            }

            if DemoWizardState.step == 0 : Text {
                text: "Generate a complete sample project with CRUD, undo/redo, events, and tests.";
                font-size: 13px;
                color: #868e96;
                horizontal-alignment: center;
                wrap: word-wrap;
            }

            Rectangle {
                vertical-stretch: 1;

                // Step 0: Setup
                if DemoWizardState.step == 0 : VerticalLayout {
                    spacing: 16px;
                    padding-top: 8px;

                    Text {
                        text: "Choose the target language:";
                        font-size: 14px;
                        color: #495057;
                    }

                    RadioOption {
                        label: "C++/Qt";
                        description: "C++ 20 and Qt 6";
                        selected: DemoWizardState.language_index == 0;
                        clicked => { DemoWizardState.language_index = 0; }
                    }

                    RadioOption {
                        label: "Rust";
                        description: "2024 edition";
                        selected: DemoWizardState.language_index == 1;
                        clicked => { DemoWizardState.language_index = 1; }
                    }

                    FormField {
                        label: "Output folder";

                        HorizontalLayout {
                            spacing: 8px;

                            StyledLineEdit {
                                text: DemoWizardState.output_path;
                                placeholder: "Default: ~/qleany-demo";
                                horizontal-stretch: 1;
                                edited(val) => {
                                    DemoWizardState.output_path = val;
                                }
                            }

                            StyledButton {
                                text: "Browse...";
                                clicked => { DemoWizardState.browse_path(); }
                            }
                        }
                    }
                }

                // Step 1: Running / Done
                if DemoWizardState.step == 1 : VerticalLayout {
                    spacing: 12px;
                    padding-top: 8px;

                    if DemoWizardState.error_message != "" : Paper {
                        bg: #fff5f5;
                        with-border: true;

                        VerticalLayout {
                            padding: 12px;

                            Text {
                                text: DemoWizardState.error_message;
                                font-size: 13px;
                                color: #c92a2a;
                                wrap: word-wrap;
                            }
                        }
                    }

                    // In-progress state
                    if DemoWizardState.error_message == "" && !DemoWizardState.completed : VerticalLayout {
                        spacing: 12px;
                        alignment: center;

                        ProgressIndicator {
                            width: 48px;
                            height: 48px;
                            indeterminate: DemoWizardState.progress < 1;
                            progress: DemoWizardState.progress / 100;
                        }

                        Text {
                            text: DemoWizardState.progress_message;
                            font-size: 14px;
                            color: #495057;
                            horizontal-alignment: center;
                            wrap: word-wrap;
                        }

                        Text {
                            text: DemoWizardState.progress >= 1 ? Math.round(DemoWizardState.progress) + "%" : "";
                            font-size: 12px;
                            color: #868e96;
                            horizontal-alignment: center;
                        }
                    }

                    // Completed state: summary
                    if DemoWizardState.error_message == "" && DemoWizardState.completed : VerticalLayout {
                        spacing: 12px;

                        // Success header
                        Text {
                            text: "Demo project generated successfully!";
                            font-size: 16px;
                            font-weight: 700;
                            color: #2b8a3e;
                        }

                        Text {
                            text: DemoWizardState.summary_stats;
                            font-size: 13px;
                            color: #495057;
                        }

                        // What you got
                        Paper {
                            bg: #f8f9fa;
                            with-border: false;

                            VerticalLayout {
                                padding: 12px;
                                spacing: 6px;

                                Text {
                                    text: "Your project includes:";
                                    font-size: 13px;
                                    font-weight: 600;
                                    color: #212529;
                                }
                                Text { text: "\u{2022} Complete CRUD infrastructure (controllers, DTOs, use cases, repositories)"; font-size: 12px; color: #495057; }
                                Text { text: "\u{2022} Multi-stack undo/redo with cascade snapshot/restore"; font-size: 12px; color: #495057; }
                                Text { text: "\u{2022} Thread-safe event system with buffering"; font-size: 12px; color: #495057; }
                                Text { text: "\u{2022} Relationship management with ordering and cascade deletion"; font-size: 12px; color: #495057; }
                                Text { text: "\u{2022} Generated test suite"; font-size: 12px; color: #495057; }
                                Text { text: "\u{2022} " + DemoWizardState.summary_ui_line; font-size: 12px; color: #495057; }
                            }
                        }

                        // Next step
                        VerticalLayout {
                            spacing: 6px;

                            Text {
                                text: "Next step:";
                                font-size: 13px;
                                font-weight: 600;
                                color: #212529;
                            }

                            CopyableCommand {
                                command: DemoWizardState.next_step_command;
                                copied: DemoWizardState.copied_to_clipboard;
                                copy => {
                                    DemoWizardState.copy_next_step();
                                }
                            }
                        }
                    }

                    Rectangle { vertical-stretch: 1; }
                }
            }

            // Navigation buttons
            HorizontalLayout {
                spacing: 12px;
                alignment: end;

                if !DemoWizardState.is_running : StyledButton {
                    text: DemoWizardState.completed ? "Close" : "Cancel";
                    clicked => { root.cancelled(); }
                }

                if DemoWizardState.completed : StyledButton {
                    text: "Open Folder";
                    primary: true;
                    clicked => { DemoWizardState.open_result_folder(); }
                }

                if DemoWizardState.step == 0 : StyledButton {
                    text: "Generate";
                    primary: true;
                    clicked => { DemoWizardState.start_demo(); }
                }
            }
        }
    }
}
