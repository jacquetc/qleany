            if (!m_uow->beginTransaction())
                throw std::runtime_error("Failed to begin transaction");

            auto mappedEntities = DtoMapperT::toEntityList(m_undoState.originalDtos);
            m_uow->update(mappedEntities);

            if (!m_uow->commit())
                throw std::runtime_error("Failed to commit transaction");

            return {};
        }
        catch (...)
        {
            m_uow->rollback();
            throw;
        }
    }

    SCU::Result<void> redo()
        requires(IsUndoable)
    {
        if (!m_hasExecuted)
            return SCU::Result<void>("Cannot redo: execute() must be called first"_L1);

        try
        {
            if (!m_uow->beginTransaction())
                throw std::runtime_error("Failed to begin transaction");

            auto mappedEntities = DtoMapperT::toEntityList(m_updatedDtos);
            m_uow->update(mappedEntities);

            if (!m_uow->commit())
                throw std::runtime_error("Failed to commit transaction");

            return {};
        }
        catch (...)
        {
            m_uow->rollback();
            throw;
        }
    }

