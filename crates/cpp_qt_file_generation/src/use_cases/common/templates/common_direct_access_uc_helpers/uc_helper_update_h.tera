class UpdateUseCase
{
  public:
    explicit UpdateUseCase(std::unique_ptr<UoWInterfaceT> uow)
        : m_uow(std::move(uow))
    {
    }
    ~UpdateUseCase() = default;

    QList<DtoT> execute(const QList<UpdateDtoT> &dtos)
    {
        if (m_hasExecuted)
            return m_updatedDtos;

        try
        {
            if (!m_uow->beginTransaction())
                throw std::runtime_error("Failed to begin transaction");

            if constexpr (IsUndoable)
            {
                QList<int> ids;
                ids.reserve(dtos.size());
                for (const auto &dto : dtos)
                    ids.append(dto.id);
                auto originalEntities = m_uow->get(ids);
                m_undoState.originalDtos = DtoMapperT::toDtoList(originalEntities);
            }

