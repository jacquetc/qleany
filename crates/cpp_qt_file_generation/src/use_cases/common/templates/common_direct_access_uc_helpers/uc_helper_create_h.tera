/******************************************************************************
 * Generic Create Use Case (with owner)
 *
 * Header-only C++20 template that replaces per-entity Create use cases.
 *
 * Template parameters:
 *   EntityT          - Entity struct (optionally has .createdAt/.updatedAt)
 *   CreateDtoT       - Creation DTO type
 *   DtoT             - Full DTO type (must have .id member)
 *   DtoMapperT       - Static mapper with toEntityList()/toDtoList()
 *   UoWInterfaceT    - Unit of work interface
 *   IsUndoable       - Compile-time flag for undo/redo support
 *   IsReplacingOwner - true for OneToOne/ManyToOne (cascade displaces existing
 *                      children), false for ordered/unordered lists (junction append)
 ******************************************************************************/

#pragma once

#include "direct_access/use_case_helpers/uc_concepts.h"
#include "database/snapshot_types.h"
#include "undo_redo/undo_redo_command.h"

#include <QDateTime>
#include <QList>
#include <memory>
#include <stdexcept>
