using namespace Qt::StringLiterals;

namespace {{ s.global.application_pascal_name }}::Common::DirectAccess::UseCaseHelpers
{

namespace SCDatabase = {{ s.global.application_pascal_name }}::Common::Database;
namespace SCU = {{ s.global.application_pascal_name }}::Common::UndoRedo;

template <typename EntityT,
          typename CreateDtoT,
          typename DtoT,
          typename DtoMapperT,
          typename UoWInterfaceT,
          bool IsUndoable = false,
          bool IsReplacingOwner = false>
class CreateUseCase
{
  public:
    explicit CreateUseCase(std::unique_ptr<UoWInterfaceT> uow)
        : m_uow(std::move(uow))
    {
    }
    ~CreateUseCase() = default;

    QList<DtoT> execute(const QList<CreateDtoT> &dtos, int ownerId, int index)
    {
        if (m_hasExecuted)
            return m_createdDtos;

        if constexpr (IsUndoable)
        {
            m_undoState.originalDtos = dtos;
            m_undoState.ownerId = ownerId;
            m_undoState.index = index;
        }

        try
        {
            if (!m_uow->beginTransaction())
                throw std::runtime_error("Failed to begin transaction");

            auto mappedEntities = DtoMapperT::toEntityList(dtos);

            if constexpr (HasTimestamps<EntityT>)
            {
                QDateTime now = QDateTime::currentDateTimeUtc();
                for (auto &entity : mappedEntities)
                {
                    entity.createdAt = now;
                    entity.updatedAt = now;
                }
            }

            if constexpr (IsUndoable)
            {
                if constexpr (IsReplacingOwner)
                {
                    m_undoState.existingChildIds = m_uow->getRelationshipsFromOwner(ownerId);
                    if (!m_undoState.existingChildIds.isEmpty())
                        m_undoState.displacedChildrenSnapshot = m_uow->snapshot(m_undoState.existingChildIds);
                }
                else
                {
                    m_undoState.previousOwnerRelationshipIds = m_uow->getRelationshipsFromOwner(ownerId);
                }
            }

            auto createdEntities = m_uow->create(mappedEntities, ownerId, index);

            if (!m_uow->commit())
                throw std::runtime_error("Failed to commit transaction");

            m_createdDtos = DtoMapperT::toDtoList(createdEntities);
            m_hasExecuted = true;
        }
        catch (...)
        {
            m_uow->rollback();
            throw;
        }

        return m_createdDtos;
    }

    SCU::Result<void> undo()
        requires(IsUndoable)
    {
        if (!m_hasExecuted || m_createdDtos.isEmpty())
            return SCU::Result<void>("Cannot undo: no entities were created"_L1);

        try
        {
            if (!m_uow->beginTransaction())
                throw std::runtime_error("Failed to begin transaction");

            QList<int> idsToRemove;
            idsToRemove.reserve(m_createdDtos.size());
            for (const auto &dto : m_createdDtos)
                idsToRemove.append(dto.id);

            m_undoState.oldTreeSnapshot = m_uow->snapshot(idsToRemove);
            m_uow->remove(idsToRemove);

            if constexpr (IsReplacingOwner)
            {
                if (!m_undoState.displacedChildrenSnapshot.tableData.entityRows.rows.isEmpty())
                {
                    m_uow->restore(m_undoState.displacedChildrenSnapshot);
                    m_uow->setRelationshipsInOwner(m_undoState.existingChildIds, m_undoState.ownerId);
                }
                else
                {
                    m_uow->setRelationshipsInOwner({}, m_undoState.ownerId);
                }
            }
            else
            {
                m_uow->setRelationshipsInOwner(m_undoState.previousOwnerRelationshipIds, m_undoState.ownerId);
            }

            if (!m_uow->commit())
                throw std::runtime_error("Failed to commit transaction");

            return SCU::Result<void>();
        }
        catch (...)
        {
            m_uow->rollback();
            throw;
        }
    }

    SCU::Result<void> redo()
        requires(IsUndoable)
    {
        if (!m_hasExecuted)
            return SCU::Result<void>("Cannot redo: execute() must be called first"_L1);

        try
        {
            if (!m_uow->beginTransaction())
                throw std::runtime_error("Failed to begin transaction");

            if constexpr (IsReplacingOwner)
            {
                if (!m_undoState.existingChildIds.isEmpty())
                {
                    m_undoState.displacedChildrenSnapshot = m_uow->snapshot(m_undoState.existingChildIds);
                    m_uow->remove(m_undoState.existingChildIds);
                }

                m_uow->restore(m_undoState.oldTreeSnapshot);

                const auto newIds = SCDatabase::SnapshotUtil::extractIds(m_undoState.oldTreeSnapshot.tableData.entityRows);
                m_uow->setRelationshipsInOwner(newIds, m_undoState.ownerId);
            }
            else
            {
                m_uow->restore(m_undoState.oldTreeSnapshot);

                auto redoJunction = m_undoState.previousOwnerRelationshipIds;
                const auto createdIds = SCDatabase::SnapshotUtil::extractIds(m_undoState.oldTreeSnapshot.tableData.entityRows);
                if (m_undoState.index >= 0 && m_undoState.index < redoJunction.size())
                {
                    for (int i = 0; i < createdIds.size(); ++i)
                        redoJunction.insert(m_undoState.index + i, createdIds.at(i));
                }
                else
                {
                    redoJunction.append(createdIds);
                }
                m_uow->setRelationshipsInOwner(redoJunction, m_undoState.ownerId);
            }

            if (!m_uow->commit())
                throw std::runtime_error("Failed to commit transaction");

            return SCU::Result<void>();
        }
        catch (...)
        {
            m_uow->rollback();
            throw;
        }
    }

  private:
    std::unique_ptr<UoWInterfaceT> m_uow;
    QList<DtoT> m_createdDtos;
    bool m_hasExecuted = false;

    struct UndoState
    {
        QList<CreateDtoT> originalDtos;
        int ownerId = 0;
        int index = -1;
        SCDatabase::EntityTreeSnapshot oldTreeSnapshot;
        // IsReplacingOwner fields
        QList<int> existingChildIds;
        SCDatabase::EntityTreeSnapshot displacedChildrenSnapshot;
        // !IsReplacingOwner fields
        QList<int> previousOwnerRelationshipIds;
    };
    struct NoState
    {
    };
    [[no_unique_address]] std::conditional_t<IsUndoable, UndoState, NoState> m_undoState{};
};

} // namespace {{ s.global.application_pascal_name }}::Common::DirectAccess::UseCaseHelpers
