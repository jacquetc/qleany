/******************************************************************************
 * Controller Command Helpers
 *
 * Template helpers that encapsulate the repetitive command/query wiring
 * found in every entity and feature controller.
 *
 * Helpers for entity controllers (single-command operations):
 * - executeUndoableCommand       — execute + push to undo stack (with result)
 * - executeUndoableCommandVoid   — execute + push to undo stack (void)
 * - executeNotUndoableCommand    — execute on throwaway stack (with result)
 * - executeNotUndoableCommandVoid— execute on throwaway stack (void)
 * - executeReadQuery             — read-only query through the system
 *
 * Helpers for command composition (GroupCommand in feature controllers):
 * - executeDeferredCommand       — execute + return command (with result)
 * - executeDeferredCommandVoid   — execute + return command (void)
 * - rollbackDeferredCommands     — undo a list of deferred commands in reverse
 *
 * Features:
 * - Configurable timeout per call
 * - UseCase lifetime managed by direct shared_ptr capture
 * - Error callback for signal-based error reporting
 * - Type-safe, debuggable, IDE-navigable
 *
 * Usage — single-command (in a generated entity controller):
 *
 *   QCoro::Task<QList<PersonDto>> PersonController::create(
 *       const QList<CreatePersonDto> &persons)
 *   {
 *       auto uow = std::make_unique<PersonUnitOfWork>(*m_dbContext, m_eventRegistry);
 *       auto useCase = std::make_shared<CreatePersonUseCase>(std::move(uow));
 *
 *       co_return co_await executeUndoableCommand<QList<PersonDto>>(
 *           m_undoRedoSystem,
 *           m_undoRedoStackId,
 *           u"Create persons Command"_s,
 *           std::move(useCase),
 *           500,
 *           [this](const QString &cmd, const QString &msg) {
 *               if (m_eventRegistry) m_eventRegistry->publishError(cmd, msg);
 *           },
 *           persons);
 *   }
 *
 * Usage — grouped commands (in a custom feature controller):
 *
 *   QCoro::Task<bool> MyFeatureController::importData(const ImportDto &dto)
 *   {
 *       QList<std::shared_ptr<UndoRedoCommand>> executed;
 *
 *       // Step 1
 *       auto [result1, cmd1] = co_await executeDeferredCommand<QList<CarDto>>(
 *           u"Create cars"_s, useCase1, 500, onError, dto.cars, ownerId, -1);
 *       if (!cmd1) co_return false;
 *       executed.append(cmd1);
 *
 *       // Step 2 (depends on step 1)
 *       auto [ok, cmd2] = co_await executeDeferredCommandVoid(
 *           u"Link tags"_s, useCase2, 500, onError, result1[0].id(), dto.tagIds);
 *       if (!cmd2) {
 *           co_await rollbackDeferredCommands(executed);
 *           co_return false;
 *       }
 *       executed.append(cmd2);
 *
 *       // Register all steps as a single undo unit
 *       auto group = std::make_shared<GroupCommand>(u"Import data"_s);
 *       for (auto &cmd : executed) group->addCommand(cmd);
 *       m_undoRedoSystem->manager()->pushCommand(group, m_undoRedoStackId);
 *       co_return true;
 *   }
 ******************************************************************************/

