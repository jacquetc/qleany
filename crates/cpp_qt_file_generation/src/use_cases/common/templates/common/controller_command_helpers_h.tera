// =============================================================================
// Read-only Query
// =============================================================================

/**
 * @brief Execute a read-only query through the undo-redo system.
 *
 * @tparam ResultT  Return type of the query
 * @tparam QueryFn  Callable returning ResultT (typically a lambda that
 *                  constructs UoW + UseCase and calls execute)
 *
 * @param undoRedoSystem The undo-redo system to execute on
 * @param queryName      Human-readable name for the query
 * @param queryFn        Callable invoked to produce the result
 *
 * @return The query result, or a default-constructed ResultT on failure.
 */
template <typename ResultT, typename QueryFn>
[[nodiscard]] QCoro::Task<ResultT> executeReadQuery(
    SCUndoRedo::UndoRedoSystem *undoRedoSystem,
    const QString &queryName,
    QueryFn &&queryFn)
{
    if (!undoRedoSystem) [[unlikely]]
    {
        qCritical() << "UndoRedo system not available";
        co_return ResultT{};
    }

    auto query = undoRedoSystem->template createQuery<ResultT>(queryName);
    query->setQueryFunction(std::forward<QueryFn>(queryFn));

    co_return co_await undoRedoSystem->executeQueryAsync(query);
}

// =============================================================================
// Deferred Command — execute without registering on any stack
// =============================================================================

/**
 * @brief Execute a use case on a background thread and return both the result
 *        and the command object, without pushing to any undo/redo stack.
 *
 * The command runs via asyncExecute() / QtConcurrent::run, identical to the
 * normal path. The difference is that the resulting command is returned to
 * the caller instead of being registered on a stack.
 *
 * Intended for feature controllers that compose multiple entity operations
 * into a single GroupCommand (one undo unit). Collect the returned commands,
 * add them to a GroupCommand, and push the group with:
 *
 *     m_undoRedoSystem->manager()->pushCommand(group, m_undoRedoStackId);
 *
 * @tparam ResultT       Return type of the use-case execute method
 * @tparam UseCaseT      UseCase type (must have execute(...), undo(), redo())
 * @tparam ExecArgs      Argument types forwarded to useCase->execute(...)
 *
 * @param commandName    Human-readable name for the command
 * @param useCase        Shared ownership of the use case
 * @param timeoutMs      Timeout in milliseconds for async execution
 * @param onError        Callback invoked on timeout or failure (commandName, message)
 * @param execArgs       Arguments forwarded to useCase->execute(...)
 *
 * @return A pair of {result, command}. On failure, command is nullptr.
 */
template <typename ResultT, typename UseCaseT, typename... ExecArgs>
[[nodiscard]] QCoro::Task<std::pair<ResultT, std::shared_ptr<SCUndoRedo::UndoRedoCommand>>>
executeDeferredCommand(
    const QString &commandName,
    std::shared_ptr<UseCaseT> useCase,
    int timeoutMs,
    std::function<void(const QString &, const QString &)> onError,
    ExecArgs... execArgs)
{
    using ReturnT = std::pair<ResultT, std::shared_ptr<SCUndoRedo::UndoRedoCommand>>;

    auto command = std::make_shared<SCUndoRedo::UndoRedoCommand>(commandName);
    ResultT result{};

    command->setExecuteFunction(
        [useCase, ...args = std::move(execArgs), &result](auto & /*promise*/) {
            result = useCase->execute(args...);
        });

    command->setRedoFunction([useCase]() -> SCUndoRedo::Result<void> {
        return useCase->redo();
    });

    command->setUndoFunction([useCase]() -> SCUndoRedo::Result<void> {
        return useCase->undo();
    });

    // Execute directly — not through any stack
    command->asyncExecute();
    auto success =
        co_await qCoro(command.get(), &SCUndoRedo::UndoRedoCommand::finished,
                        std::chrono::milliseconds(timeoutMs));

    if (!success.has_value()) [[unlikely]]
    {
        QString msg = commandName + " timed out"_L1;
        qWarning() << msg;
        if (onError) onError(commandName, msg);
        co_return ReturnT{ResultT{}, nullptr};
    }

    if (!success.value()) [[unlikely]]
    {
        QString msg = "Failed to execute "_L1 + commandName;
        qWarning() << msg;
        if (onError) onError(commandName, msg);
        co_return ReturnT{ResultT{}, nullptr};
    }

    co_return ReturnT{std::move(result), command};
}

// =============================================================================
// Deferred Command — void execute (no return value)
// =============================================================================

/**
 * @brief Execute a use case on a background thread and return the command
 *        object, without pushing to any undo/redo stack.
 *
 * Same as executeDeferredCommand but for use cases whose execute() returns void.
 *
 * @return A pair of {success, command}. On failure, command is nullptr.
 */
template <typename UseCaseT, typename... ExecArgs>
[[nodiscard]] QCoro::Task<std::pair<bool, std::shared_ptr<SCUndoRedo::UndoRedoCommand>>>
executeDeferredCommandVoid(
    const QString &commandName,
    std::shared_ptr<UseCaseT> useCase,
    int timeoutMs,
    std::function<void(const QString &, const QString &)> onError,
    ExecArgs... execArgs)
{
    using ReturnT = std::pair<bool, std::shared_ptr<SCUndoRedo::UndoRedoCommand>>;

    auto command = std::make_shared<SCUndoRedo::UndoRedoCommand>(commandName);

    command->setExecuteFunction(
        [useCase, ...args = std::move(execArgs)](auto & /*promise*/) {
            useCase->execute(args...);
        });

    command->setRedoFunction([useCase]() -> SCUndoRedo::Result<void> {
        return useCase->redo();
    });

    command->setUndoFunction([useCase]() -> SCUndoRedo::Result<void> {
        return useCase->undo();
    });

    // Execute directly — not through any stack
    command->asyncExecute();
    auto success =
        co_await qCoro(command.get(), &SCUndoRedo::UndoRedoCommand::finished,
                        std::chrono::milliseconds(timeoutMs));

    if (!success.has_value()) [[unlikely]]
    {
        QString msg = commandName + " timed out"_L1;
        qWarning() << msg;
        if (onError) onError(commandName, msg);
        co_return ReturnT{false, nullptr};
    }

    if (!success.value()) [[unlikely]]
    {
        QString msg = "Failed to execute "_L1 + commandName;
        qWarning() << msg;
        if (onError) onError(commandName, msg);
        co_return ReturnT{false, nullptr};
    }

    co_return ReturnT{true, command};
}

// =============================================================================
// Rollback Deferred Commands
// =============================================================================

/**
 * @brief Undo a list of already-executed deferred commands in reverse order.
 *
 * Use this to roll back partial progress when a grouped operation fails
 * mid-way. Each command's asyncUndo() runs on a background thread via
 * QtConcurrent::run, same as normal undo operations.
 *
 * @param commands   The commands to undo, in the order they were executed.
 *                   They will be undone in reverse order.
 * @param timeoutMs  Timeout per individual undo operation (default 500ms).
 *
 * @return true if all rollbacks succeeded, false if any failed.
 */
[[nodiscard]] inline QCoro::Task<bool> rollbackDeferredCommands(
    const QList<std::shared_ptr<SCUndoRedo::UndoRedoCommand>> &commands,
    int timeoutMs = 500)
{
    for (auto it = commands.rbegin(); it != commands.rend(); ++it)
    {
        (*it)->asyncUndo();
        auto success =
            co_await qCoro(it->get(), &SCUndoRedo::UndoRedoCommand::finished,
                            std::chrono::milliseconds(timeoutMs));

        if (!success.has_value() || !success.value())
        {
            qWarning() << "Rollback failed for command:" << (*it)->text();
            co_return false;
        }
    }
    co_return true;
}

