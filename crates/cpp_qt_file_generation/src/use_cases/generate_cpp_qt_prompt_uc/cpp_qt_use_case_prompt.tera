Common::UndoRedo::Result<void> {{ uc.pascal_name }}UseCase::undo()
{
    try
    {
        if (!m_uow->beginTransaction())
            throw std::runtime_error("Failed to begin transaction");

        // Restore the snapshot captured during execute()
        m_uow->restoreEntityName(m_undoSnapshot);

        if (!m_uow->commit())
            throw std::runtime_error("Failed to commit transaction");
    }
    catch (...)
    {
        m_uow->rollback();
        throw;
    }

    m_uow->publish{{ uc.pascal_name }}Signal();
    return Common::UndoRedo::Result<void>::ok();
}

Common::UndoRedo::Result<void> {{ uc.pascal_name }}UseCase::redo()
{
    // Re-execute the forward operation (or restore a post-execute snapshot)
    execute(/* same args */);
    return Common::UndoRedo::Result<void>::ok();
}
```

