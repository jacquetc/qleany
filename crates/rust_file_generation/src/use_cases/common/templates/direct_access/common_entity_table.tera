                        _junction_complete = false;
                    }
                }
                    {%- endif %}
                {%- endif %}
                {%- endfor %}
                if _junction_complete { Some(entity) } else { None }
            } else {
                None
            };
            list.push(item);
        }

        Ok(list)
    }

