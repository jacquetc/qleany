        let mut ctx = TestContext::new();
        let created = create_one(&mut ctx);
{%- for rel_id, rel in s.entities[e].forward_relationships %}
{%- if loop.first %}
        let count = get_relationship_count(
            &ctx.db,
            &created.id,
            &{{ s.entities[e].pascal_name }}RelationshipField::{{ rel.field_pascal_name }},
        )
        .unwrap();
{%- if rel.inner.relationship_type == "OneToOne" and rel.inner.cardinality == "One" %}
        // Required OneToOne: default EntityId (0) is stored as a relationship entry
        assert_eq!(count, 1);
{%- else %}
        assert_eq!(count, 0);
{%- endif %}
{%- endif %}
{%- endfor %}
    }
{%- endif %}
