    func testGetRootAsync() async throws {
        // Root may or may not exist depending on initialization.
        // This test verifies the async wrapper doesn't crash.
        let _ = try await backend.get{{ entity.pascal_name }}Async(id: 1)
    }

    func testGetAll{{ entity.pascal_name }}Async() async throws {
        let results = try await backend.getAll{{ entity.pascal_name }}Async()
        // Should return an array (possibly empty)
        XCTAssertNotNil(results)
