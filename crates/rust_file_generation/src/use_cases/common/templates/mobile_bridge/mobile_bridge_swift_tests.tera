    override func tearDown() {
        backend.shutdown()
        backend = nil
        super.tearDown()
    }

    // MARK: - Lifecycle

    func testBackendLifecycle() {
        // Backend should be created and shut down without error.
        // setUp/tearDown handle this; reaching here means success.
        XCTAssertNotNil(backend)
    }

    func testCancelNonexistentOperation() {
        let result = backend.cancelOperation(operationId: "nonexistent-op-id")
        XCTAssertFalse(result)
    }

