import XCTest
@testable import {{ s.global.inner.application_name }}

final class MobileBridgeTests: XCTestCase {

    private var backend: MobileBackend!

    override func setUp() {
        super.setUp()
        backend = MobileBackend()
    }

    override func tearDown() {
        backend.shutdown()
        backend = nil
        super.tearDown()
    }

    // MARK: - Lifecycle

    func testBackendLifecycle() {
        // Backend should be created and shut down without error.
        // setUp/tearDown handle this; reaching here means success.
        XCTAssertNotNil(backend)
    }

    func testCancelNonexistentOperation() {
        let result = backend.cancelOperation(operationId: "nonexistent-op-id")
        XCTAssertFalse(result)
    }

    // MARK: - Entity CRUD (async)
{%- for eid, entity in s.entities %}
{%- if not entity.inner.only_for_heritage %}
