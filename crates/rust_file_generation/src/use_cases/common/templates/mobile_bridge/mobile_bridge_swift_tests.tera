    // MARK: - Event System

    /// Test event listener that collects events.
    private class TestEventListener: MobileEventListener {
        let events = NSMutableArray()
        let expectation: XCTestExpectation?

        init(expectation: XCTestExpectation? = nil) {
            self.expectation = expectation
        }

        func onEvent(event: MobileEvent) {
            events.add(event)
            expectation?.fulfill()
        }
    }

    func testSetAndRemoveEventListener() {
        let listener = TestEventListener()
        backend.setEventListener(listener: listener)
        backend.removeEventListener()
        // Should not crash
    }

    func testEventListenerReceivesEvents() async throws {
        let expectation = self.expectation(description: "Event received")
        let listener = TestEventListener(expectation: expectation)
        backend.setEventListener(listener: listener)

        // Trigger a mutation to generate an event
        // (The specific entity doesn't matter — any mutation emits an event)

        await fulfillment(of: [expectation], timeout: 5.0, enforceOrder: false)
        XCTAssertGreaterThan(listener.events.count, 0)
    }

    // MARK: - Undo/Redo

    func testUndoRedoStackLifecycle() {
        // Initially nothing to undo or redo
        XCTAssertFalse(backend.canUndo(stackId: nil))
        XCTAssertFalse(backend.canRedo(stackId: nil))

        // Create a new stack
        let stackId = backend.createNewStack()
        XCTAssertEqual(backend.getStackSize(stackId: stackId), 0)
        XCTAssertFalse(backend.canUndo(stackId: stackId))
        XCTAssertFalse(backend.canRedo(stackId: stackId))

        // Delete the stack
        try! backend.deleteStack(stackId: stackId)
    }

    func testUndoRedoComposite() {
        // Composite begin/cancel should not crash
        backend.beginComposite(stackId: nil)
        backend.cancelComposite()
    }

    func testUndoRedoClear() {
        let stackId = backend.createNewStack()
        backend.clearStack(stackId: stackId)
        backend.clearAllStacks()
        try! backend.deleteStack(stackId: stackId)
    }

    func testUndoRedoStackLifecycleAsync() async throws {
        let stackId = await backend.createNewStackAsync()
        XCTAssertEqual(backend.getStackSize(stackId: stackId), 0)
        try await backend.deleteStackAsync(stackId: stackId)
    }

    func testMobileEventKindVariants() {
        // Verify key variants are distinct
        XCTAssertNotEqual(MobileEventKind.reset, MobileEventKind.undoPerformed)
        XCTAssertNotEqual(MobileEventKind.longOperationStarted, MobileEventKind.longOperationCompleted)
    }
}
