        NavigationStack {
            Form {
{%- if demo_first_string_field_camel != "" %}
                Section("New {{ demo_pascal }}") {
                    TextField("{{ demo_first_string_field_camel | capitalize }}", text: $new{{ demo_first_string_field_camel | capitalize }})
                }
{%- else %}
                Section("New {{ demo_pascal }}") {
                    Text("Add fields from MobileCreate{{ demo_pascal }}Dto here")
                }
{%- endif %}
            }
            .navigationTitle("Create {{ demo_pascal }}")
            .navigationBarTitleDisplayMode(.inline)
            .toolbar {
                ToolbarItem(placement: .cancellationAction) {
                    Button("Cancel") { showCreateSheet = false }
                }
                ToolbarItem(placement: .confirmationAction) {
                    Button("Create") {
                        Task {
                            // TODO: Construct a full MobileCreate{{ demo_pascal }}Dto here.
                            // This placeholder only demonstrates the creation flow.
                            // await backend.createItem(dto: MobileCreate{{ demo_pascal }}Dto(...))
