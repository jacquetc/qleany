class MobileBridgeTest {

    private lateinit var backend: MobileBackend

    @Before
    fun setUp() {
        backend = MobileBackend()
    }

    @After
    fun tearDown() {
        backend.shutdown()
    }

    // Lifecycle

    @Test
    fun testBackendLifecycle() {
        // Backend should be created and shut down without error.
        // setUp/tearDown handle this; reaching here means success.
        assertNotNull(backend)
    }

    @Test
    fun testCancelNonexistentOperation() {
        val result = backend.cancelOperation("nonexistent-op-id")
        assertFalse(result)
    }

