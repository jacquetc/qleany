    // Event System

    @Test
    fun testSetAndRemoveEventListener() {
        val listener = object : MobileEventListener {
            override fun onEvent(event: MobileEvent) {}
        }
        backend.setEventListener(listener)
        backend.removeEventListener()
        // Should not crash
    }

    @Test
    fun testEventListenerReceivesEvents() {
        val events = mutableListOf<MobileEvent>()
        val latch = java.util.concurrent.CountDownLatch(1)
        val listener = object : MobileEventListener {
            override fun onEvent(event: MobileEvent) {
                events.add(event)
                latch.countDown()
            }
        }
        backend.setEventListener(listener)

        // Trigger a mutation to generate an event
        // (Events are delivered asynchronously via the dispatch thread)

        // Wait up to 5 seconds for an event
        latch.await(5, java.util.concurrent.TimeUnit.SECONDS)
    }

    // Undo/Redo

    @Test
    fun testUndoRedoStackLifecycle() {
        // Initially nothing to undo or redo
        assertFalse(backend.canUndo(null))
        assertFalse(backend.canRedo(null))

        // Create a new stack
        val stackId = backend.createNewStack()
        assertEquals(0uL, backend.getStackSize(stackId))
        assertFalse(backend.canUndo(stackId))
        assertFalse(backend.canRedo(stackId))

        // Delete the stack
        backend.deleteStack(stackId)
    }

    @Test
    fun testUndoRedoComposite() {
        // Composite begin/cancel should not crash
        backend.beginComposite(null)
        backend.cancelComposite()
    }

    @Test
    fun testUndoRedoClear() {
        val stackId = backend.createNewStack()
        backend.clearStack(stackId)
        backend.clearAllStacks()
        backend.deleteStack(stackId)
    }

    @Test
    fun testUndoRedoStackLifecycleAsync() = runBlocking {
        val stackId = backend.createNewStackAsync()
        assertEquals(0uL, backend.getStackSize(stackId))
        backend.deleteStackAsync(stackId)
    }

    @Test
    fun testMobileEventKindVariants() {
        // Verify key variants are distinct
        assertNotEquals(MobileEventKind.RESET, MobileEventKind.UNDO_PERFORMED)
        assertNotEquals(MobileEventKind.LONG_OPERATION_STARTED, MobileEventKind.LONG_OPERATION_COMPLETED)
    }
}
