package {{ s.global.inner.organisation_domain }}.{{ s.global.application_snake_name }}.bridge

import kotlinx.coroutines.runBlocking
import org.junit.After
import org.junit.Assert.*
import org.junit.Before
import org.junit.Test

class MobileBridgeTest {

    private lateinit var backend: MobileBackend

    @Before
    fun setUp() {
        backend = MobileBackend()
    }

    @After
    fun tearDown() {
        backend.shutdown()
    }

    // Lifecycle

    @Test
    fun testBackendLifecycle() {
        // Backend should be created and shut down without error.
        // setUp/tearDown handle this; reaching here means success.
        assertNotNull(backend)
    }

    @Test
    fun testCancelNonexistentOperation() {
        val result = backend.cancelOperation("nonexistent-op-id")
        assertFalse(result)
    }

    // Entity CRUD (suspend)
{%- for eid, entity in s.entities %}
{%- if not entity.inner.only_for_heritage %}
{%- if entity.pascal_name == "Root" %}

    @Test
    fun testGetRootAsync() = runBlocking {
        // Root may or may not exist depending on initialization.
        // This test verifies the suspend wrapper doesn't crash.
        backend.get{{ entity.pascal_name }}Async(1uL)
    }

    @Test
    fun testGetAll{{ entity.pascal_name }}Async() = runBlocking {
        val results = backend.getAll{{ entity.pascal_name }}Async()
        // Should return a list (possibly empty)
        assertNotNull(results)
    }
