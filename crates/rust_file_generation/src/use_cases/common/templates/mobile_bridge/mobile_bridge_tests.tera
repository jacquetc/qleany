//! Integration tests for the mobile bridge.
//!
//! These tests verify that MobileBackend correctly wraps the frontend
//! commands. No device or emulator is needed — the backend runs in-process.

#[cfg(test)]
mod tests {
    use mobile_bridge::MobileBackend;
    use std::sync::Arc;

    #[test]
    fn test_backend_lifecycle() {
        let backend = MobileBackend::new();
        // Backend should be created successfully
        assert!(Arc::strong_count(&backend) >= 1);
        backend.shutdown();
    }

    #[test]
    fn test_cancel_nonexistent_operation() {
        let backend = MobileBackend::new();
        // Cancelling a non-existent operation should return false
        let result = backend.cancel_operation("nonexistent-op-id".to_string());
        assert!(!result);
        backend.shutdown();
    }
}
