//! Integration tests for the mobile bridge.
//!
//! These tests verify that MobileBackend correctly wraps the frontend
//! commands. No device or emulator is needed — the backend runs in-process.

#[cfg(test)]
mod tests {
    use mobile_bridge::{MobileBackend, MobileEvent, MobileEventKind, MobileEventListener};
    use std::sync::{Arc, Mutex};

    #[test]
    fn test_backend_lifecycle() {
        let backend = MobileBackend::new();
        // Backend should be created successfully
        assert!(Arc::strong_count(&backend) >= 1);
        backend.shutdown();
    }

    #[test]
    fn test_cancel_nonexistent_operation() {
        let backend = MobileBackend::new();
        // Cancelling a non-existent operation should return false
        let result = backend.cancel_operation("nonexistent-op-id".to_string());
        assert!(!result);
        backend.shutdown();
    }

    /// A test event listener that collects events into a shared vec.
    struct TestEventListener {
        events: Arc<Mutex<Vec<MobileEvent>>>,
    }

    impl MobileEventListener for TestEventListener {
        fn on_event(&self, event: MobileEvent) {
            self.events.lock().unwrap().push(event);
        }
    }

    #[test]
    fn test_set_and_remove_event_listener() {
        let backend = MobileBackend::new();
        let events = Arc::new(Mutex::new(Vec::new()));
        let listener = Arc::new(TestEventListener {
            events: Arc::clone(&events),
        });
        // Setting a listener should not panic
        backend.set_event_listener(listener);
        // Removing it should not panic either
        backend.remove_event_listener();
        backend.shutdown();
    }

    #[test]
    fn test_event_listener_receives_events() {
        let backend = MobileBackend::new();
        let events = Arc::new(Mutex::new(Vec::new()));
        let listener = Arc::new(TestEventListener {
            events: Arc::clone(&events),
        });
        backend.set_event_listener(listener);

        // Trigger an entity event by creating an orphan entity.
        // We only need one — break after the first ownerless entity.
        {%- for eid, ent in s.entities %}
        {%- if not ent.inner.only_for_heritage and not ent.owner %}
        {
            let dto = mobile_bridge::{{ ent.snake_name }}_commands::MobileCreate{{ ent.pascal_name }}Dto {
                {%- for f in ent.fields %}
                {%- if f.snake_name != "created_at" and f.snake_name != "updated_at" %}
                {{ f.snake_name }}:
                {%- if f.is_list %} vec![]
                {%- elif f.optional %} None
                {%- elif f.inner.field_type == "Boolean" %} false
                {%- elif f.inner.field_type == "Integer" %} 0
                {%- elif f.inner.field_type == "UInteger" %} 0
                {%- elif f.inner.field_type == "Float" %} 0.0
                {%- elif f.inner.field_type == "String" %} String::new()
                {%- elif f.inner.field_type == "Entity" %} 0
                {%- else %} Default::default()
                {%- endif %},
                {%- endif %}
                {%- endfor %}
            };
            let _ = backend.create_orphan_{{ ent.snake_name }}(
                {%- if ent.inner.undoable %}
                None,
                {%- endif %}
                dto,
            );
        }
        {% break %}
        {%- endif %}
        {%- endfor %}

        // Give the dispatch thread time to deliver
        std::thread::sleep(std::time::Duration::from_millis(1000));

        let received = events.lock().unwrap();
        assert!(
            !received.is_empty(),
            "Expected at least one event to be delivered"
        );

        backend.shutdown();
    }

    #[test]
    fn test_undo_redo_stack_lifecycle() {
        let backend = MobileBackend::new();

        // Initially nothing to undo or redo on default stack
        assert!(!backend.can_undo(None));
        assert!(!backend.can_redo(None));

        // Create a new stack
        let stack_id = backend.create_new_stack();
        assert_eq!(backend.get_stack_size(stack_id), 0);
        assert!(!backend.can_undo(Some(stack_id)));
        assert!(!backend.can_redo(Some(stack_id)));

        // Delete the stack
        backend.delete_stack(stack_id).unwrap();

        backend.shutdown();
    }

    #[test]
    fn test_undo_redo_composite() {
        let backend = MobileBackend::new();

        // Composite begin/end/cancel should not panic even with no commands
        backend.begin_composite(None);
        backend.cancel_composite();

        backend.shutdown();
    }

    #[test]
    fn test_undo_redo_clear() {
        let backend = MobileBackend::new();

        let stack_id = backend.create_new_stack();
        // Clear specific stack
        backend.clear_stack(stack_id);
        // Clear all stacks
        backend.clear_all_stacks();

        backend.delete_stack(stack_id).unwrap();
        backend.shutdown();
    }

    #[test]
    fn test_mobile_event_kind_variants() {
        // Verify key variants exist and are distinct
        assert_ne!(MobileEventKind::Reset, MobileEventKind::UndoPerformed);
        assert_ne!(
            MobileEventKind::LongOperationStarted,
            MobileEventKind::LongOperationCompleted
        );
    }
}
